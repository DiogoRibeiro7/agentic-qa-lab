# Copy to .env and fill in your values. The real .env is gitignored.
# Settings are loaded via pydantic-settings (see src/agentic_qa_lab/config.py).

# --- LLM planner (any OpenAI-compatible provider) -------------------------
# Required only when using the `llm` agent.
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Optional generation controls (defaults shown):
# LLM_TEMPERATURE=0.0
# LLM_TIMEOUT=30.0

# --- API service / dashboard ----------------------------------------------
# Directory the FastAPI service reads/writes run JSON files to.
AGENTIC_QA_STORE_DIR=artifacts/runs
# Base URL the Streamlit dashboard calls (defaults to http://localhost:8000).
# AGENTIC_QA_API_URL=http://localhost:8000

# --- Runtime --------------------------------------------------------------
# AGENTIC_QA_ENVIRONMENT=local
# AGENTIC_QA_DEBUG=false
# AGENTIC_QA_RANDOM_SEED=42

# --- Task secrets ---------------------------------------------------------
# Tasks reference secrets by env name, e.g. text: {env: AGENTIC_QA_EXAMPLE_LOGIN_PASSWORD}
# AGENTIC_QA_EXAMPLE_LOGIN_PASSWORD=changeme

# --- Tests ----------------------------------------------------------------
# Set to 1 (with Chromium installed) to run opt-in live network tests.
# AGENTIC_QA_RUN_NETWORK_TESTS=0
